###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto

###############################################################################
# Set default behavior for command prompt diff.
###############################################################################
#*.cs     diff=csharp

###############################################################################
# Set the merge driver for project and solution files
###############################################################################
*.sln       merge=binary
*.csproj    merge=binary
*.vbproj    merge=binary
*.vcxproj   merge=binary
*.vcproj    merge=binary
*.dbproj    merge=binary
*.fsproj    merge=binary
*.lsproj    merge=binary
*.wixproj   merge=binary
*.modelproj merge=binary
*.sqlproj   merge=binary
*.wwaproj   merge=binary

###############################################################################
# Git LFS 专属目录 美术资源只存最新不存历史
# 对应路径：E:\GitLDYQReSkin\Unity\Assets\Art  ArtUI
###############################################################################
/Unity/Assets/Art/**     filter=lfs diff=lfs merge=lfs -text
/Unity/Assets/ArtUI/**   filter=lfs diff=lfs merge=lfs -text
/Unity/Assets/Plugins/**   filter=lfs diff=lfs merge=lfs -text
/Unity/Assets/Plugins/**   filter=lfs diff=lfs merge=lfs -text

###############################################################################
# 图片二进制统一LFS
###############################################################################
*.jpg   filter=lfs diff=lfs merge=lfs -text
*.png   filter=lfs diff=lfs merge=lfs -text
*.gif   filter=lfs diff=lfs merge=lfs -text
*.tga   filter=lfs diff=lfs merge=lfs -text
*.psd   filter=lfs diff=lfs merge=lfs -text
*.fbx   filter=lfs diff=lfs merge=lfs -text
*.wav   filter=lfs diff=lfs merge=lfs -text

